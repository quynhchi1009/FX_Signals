//@version=6
indicator("Engulfing Indicator", overlay=true, max_labels_count=500, max_boxes_count=500, max_lines_count=500)

// === INPUTS ===

// === DISPLAY ===
grpDisp = "DISPLAY"
show_sl_tp = input.bool(true, "Show SL/TP Lines", tooltip="Draw dashed SL (red) and TP (green) from each signal bar, extending to the right.", group=grpDisp)
line_extend_bars = input.int(10, "SL/TP Line Length (bars)", minval=1, maxval=500, tooltip="Horizontal line segment length in bar indices from the signal bar.", group=grpDisp)
show_table = input.bool(true, "Show Filter Status Table", tooltip="Top-right table of per-bar filter status.", group=grpDisp)

// === ENGULFING ===
grpEng = "ENGULFING"
is_forex = input.bool(true, "Forex pip mode", tooltip="If true, 1 pip = syminfo.mintick × 10 (typical FX). If false, 1 pip = syminfo.mintick.", group=grpEng)
min_candle_pips = input.float(5.0, "Minimum body (pips)", minval=0.0, step=0.1, tooltip="Engulfing candle body must be at least this many pips.", group=grpEng)

// === EMA FILTER ===
grpEma = "EMA FILTER"
ema_filter_enabled = input.bool(true, "Enable EMA filter", tooltip="When off, fast/slow EMA alignment is not required for signals (length inputs are disabled).", group=grpEma)
ema_fast_len = input.int(20, "Fast EMA length", minval=1, tooltip="Fast exponential moving average period.", group=grpEma, active=ema_filter_enabled)
ema_slow_len = input.int(50, "Slow EMA length", minval=1, tooltip="Slow exponential moving average period.", group=grpEma, active=ema_filter_enabled)

// === ATR FILTER ===
grpAtr = "ATR FILTER"
atr_filter_enabled = input.bool(true, "Enable ATR filter", tooltip="When off, candle range vs ATR is not checked (ATR inputs are disabled).", group=grpAtr)
atr_len = input.int(14, "ATR length", minval=1, tooltip="Average True Range lookback.", group=grpAtr, active=atr_filter_enabled)
atr_multiplier = input.float(1.5, "ATR multiplier (max range)", minval=0.01, step=0.1, tooltip="Signal candle range (high−low) vs ATR × this value.", group=grpAtr, active=atr_filter_enabled)
atr_inclusive = input.bool(false, "ATR: allow equality (≤)", tooltip="Off: range strictly < ATR×mult. On: range ≤ ATR×mult.", group=grpAtr, active=atr_filter_enabled)

// === TREND BIAS ===
grpTrend = "TREND BIAS"
trend_filter_enabled = input.bool(true, "Enable trend bias filter", tooltip="When off, pivot HH/HL vs LH/LL bias is not required (pivot lookback is disabled).", group=grpTrend)
trend_lookback = input.int(5, "Pivot bars to evaluate", minval=2, maxval=50, tooltip="Number of recent confirmed pivot highs/lows used for HH/HL or LH/LL bias.", group=grpTrend, active=trend_filter_enabled)

// === SESSION FILTER ===
grpSess = "SESSION FILTER"
session_filter_enabled = input.bool(true, "Block 21:45–22:15 UTC", tooltip="When enabled, no new signals during this UTC window.", group=grpSess)

// --- helpers (drawing / pivot checks; used below)
f_store_box(array<box> arr, box b) =>
    array.push(arr, b)
    while array.size(arr) > 498
        box.delete(array.get(arr, 0))
        array.remove(arr, 0)

f_store_two_lines(array<line> arr, line l1, line l2) =>
    array.push(arr, l1)
    array.push(arr, l2)
    while array.size(arr) > 498
        line.delete(array.get(arr, 0))
        array.remove(arr, 0)

f_strict_higher(array<float> arr) =>
    ok = true
    if array.size(arr) < trend_lookback
        ok := false
    else
        for i = 0 to trend_lookback - 2
            if array.get(arr, i) <= array.get(arr, i + 1)
                ok := false
                break
    ok

f_strict_lower(array<float> arr) =>
    ok = true
    if array.size(arr) < trend_lookback
        ok := false
    else
        for i = 0 to trend_lookback - 2
            if array.get(arr, i) >= array.get(arr, i + 1)
                ok := false
                break
    ok

// === CALCULATIONS ===

// Pip size: FX convention vs generic tick
pip_size = is_forex ? syminfo.mintick * 10.0 : syminfo.mintick

// Session: block 21:45 – 22:15 UTC (inclusive)
h_utc = hour(time, "UTC")
m_utc = minute(time, "UTC")
tod_utc = h_utc * 60 + m_utc
session_blocked = session_filter_enabled and tod_utc >= (21 * 60 + 45) and tod_utc <= (22 * 60 + 15)

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
atr_val = ta.atr(atr_len)

// Engulfing (current vs previous): wick engulfs range; close clears prior BODY high/low (your rule)
h1 = high[1]
l1 = low[1]
prev_open = open[1]
prev_close = close[1]
prev_body_high = math.max(prev_open, prev_close)
prev_body_low = math.min(prev_open, prev_close)

body = math.abs(close - open)
upper_wick = high - math.max(close, open)
lower_wick = math.min(close, open) - low

wick_ok = body > 0 and upper_wick < body and lower_wick < body

bear_eng =
     high >= h1 and
     low <= l1 and
     close < prev_body_low and
     wick_ok

bull_eng =
     high >= h1 and
     low <= l1 and
     close > prev_body_high and
     wick_ok

// Minimum body (pips)
body_pips = body / pip_size
min_body_ok = body_pips >= min_candle_pips

// ATR range
candle_range = high - low
atr_ok = not na(atr_val) and (atr_inclusive ? candle_range <= atr_multiplier * atr_val : candle_range < atr_multiplier * atr_val)
atr_pass = not atr_filter_enabled or atr_ok

// EMA filter legs
ema_buy_ok = ema_fast > ema_slow
ema_sell_ok = ema_fast < ema_slow

// Pivot trend bias (arrays of last N pivot values, newest first)
var array<float> pivot_high_vals = array.new_float(0)
var array<float> pivot_low_vals = array.new_float(0)

lb = trend_lookback
ph = ta.pivothigh(high, lb, lb)
pl = ta.pivotlow(low, lb, lb)

if not na(ph)
    array.unshift(pivot_high_vals, ph)
    while array.size(pivot_high_vals) > trend_lookback
        array.pop(pivot_high_vals)

if not na(pl)
    array.unshift(pivot_low_vals, pl)
    while array.size(pivot_low_vals) > trend_lookback
        array.pop(pivot_low_vals)

buy_bias = f_strict_higher(pivot_low_vals) and f_strict_higher(pivot_high_vals)
sell_bias = f_strict_lower(pivot_low_vals) and f_strict_lower(pivot_high_vals)

// Minimum bars (pivots + ATR + EMA)
min_bars = math.max(ema_slow_len, atr_filter_enabled ? atr_len : 0, trend_filter_enabled ? (lb * 2 + 1) : 0) + 5
bars_ok = bar_index >= min_bars and (not atr_filter_enabled or not na(atr_val))

filter_ok = not session_blocked and bars_ok and min_body_ok and atr_pass

// SL/TP reference distances (same as strategy: entry = close at signal bar)
sl_dist_long = close - low
sl_dist_short = high - close

// Table row helpers (per-bar component status, independent of final signal)
session_table_ok = not session_blocked
trend_table_txt = trend_filter_enabled ? (buy_bias ? "BUY" : sell_bias ? "SELL" : "NONE") : "OFF"
ema_table_ok = ema_buy_ok or ema_sell_ok
atr_table_ok = not na(atr_val) and atr_ok

// === SIGNALS ===

bullish_signal = bull_eng and filter_ok and (not ema_filter_enabled or ema_buy_ok) and (not trend_filter_enabled or buy_bias)
bearish_signal = bear_eng and filter_ok and (not ema_filter_enabled or ema_sell_ok) and (not trend_filter_enabled or sell_bias)

// === VISUALS ===

var array<box> box_store = array.new_box()
var array<line> line_store = array.new_line()
var table info_tbl = na

// Clear SL/TP lines when disabled
if not show_sl_tp
    while array.size(line_store) > 0
        line.delete(array.pop(line_store))

// Bar color
barcolor(bullish_signal ? color.new(#00E676, 0) : bearish_signal ? color.new(#FF1744, 0) : na)

// Arrows
plotshape(bullish_signal, title="Buy Arrow", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(bearish_signal, title="Sell Arrow", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal)

// Labels, boxes, lines on signals
if bullish_signal
    label.new(bar_index, low, "ENG BUY", style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.small)
    nb = box.new(bar_index, high, bar_index, low, xloc=xloc.bar_index, border_color=color.new(color.green, 0), bgcolor=color.new(color.green, 85), border_width=2)
    f_store_box(box_store, nb)
    if show_sl_tp
        x_r = bar_index + line_extend_bars
        tp_px = close + sl_dist_long
        ls = line.new(bar_index, low, x_r, low, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.red, 0), style=line.style_dashed, width=1)
        lt = line.new(bar_index, tp_px, x_r, tp_px, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.green, 0), style=line.style_dashed, width=1)
        f_store_two_lines(line_store, ls, lt)

if bearish_signal
    label.new(bar_index, high, "ENG SELL", style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.small)
    nb = box.new(bar_index, high, bar_index, low, xloc=xloc.bar_index, border_color=color.new(color.red, 0), bgcolor=color.new(color.red, 85), border_width=2)
    f_store_box(box_store, nb)
    if show_sl_tp
        x_r = bar_index + line_extend_bars
        tp_px = close - sl_dist_short
        ls = line.new(bar_index, high, x_r, high, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.red, 0), style=line.style_dashed, width=1)
        lt = line.new(bar_index, tp_px, x_r, tp_px, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.green, 0), style=line.style_dashed, width=1)
        f_store_two_lines(line_store, ls, lt)

// EMA plots
plot(ema_fast, title="EMA Fast", color=color.orange, linewidth=1)
plot(ema_slow, title="EMA Slow", color=color.blue, linewidth=2)

// Filter status table
if show_table
    if na(info_tbl)
        info_tbl := table.new(position.top_right, 2, 6, border_width=1, frame_color=color.new(color.gray, 30), bgcolor=color.new(color.black, 75))
    table.cell(info_tbl, 0, 0, "Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60))
    table.cell(info_tbl, 1, 0, "Status", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60))

    table.cell(info_tbl, 0, 1, "Session OK", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    table.cell(info_tbl, 1, 1, session_table_ok ? "✅" : "❌", text_color=color.white, text_size=size.small, bgcolor=session_table_ok ? color.new(color.green, 70) : color.new(color.red, 70))

    table.cell(info_tbl, 0, 2, "Trend Bias", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    trend_bg = not trend_filter_enabled ? color.new(color.gray, 75) : buy_bias ? color.new(color.green, 70) : sell_bias ? color.new(color.red, 70) : color.new(color.gray, 70)
    table.cell(info_tbl, 1, 2, trend_table_txt, text_color=color.white, text_size=size.small, bgcolor=trend_bg)

    table.cell(info_tbl, 0, 3, "EMA Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    ema_stat = not ema_filter_enabled ? "OFF" : ema_table_ok ? "✅" : "❌"
    ema_bg = not ema_filter_enabled ? color.new(color.gray, 75) : ema_table_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 3, ema_stat, text_color=color.white, text_size=size.small, bgcolor=ema_bg)

    table.cell(info_tbl, 0, 4, "ATR Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    atr_stat = not atr_filter_enabled ? "OFF" : atr_table_ok ? "✅" : "❌"
    atr_bg = not atr_filter_enabled ? color.new(color.gray, 75) : atr_table_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 4, atr_stat, text_color=color.white, text_size=size.small, bgcolor=atr_bg)

    table.cell(info_tbl, 0, 5, "Min Size", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    table.cell(info_tbl, 1, 5, min_body_ok ? "✅" : "❌", text_color=color.white, text_size=size.small, bgcolor=min_body_ok ? color.new(color.green, 70) : color.new(color.red, 70))
else
    if not na(info_tbl)
        table.delete(info_tbl)
        info_tbl := na
