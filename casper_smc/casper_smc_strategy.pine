// ============================================================
// @name:        Casper SMC 15M Strategy
// @version_tag: 4.0
// @timeframe:   M1 / M5 / M15 (recommended: M5)
// @author:      [Your Name]
// ============================================================
//@version=6
strategy("Casper SMC 15M Strategy v4.0", overlay=true,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 1,
    commission_type   = strategy.commission.cash_per_contract,
    commission_value  = 0.0,
    slippage          = 1,
    max_lines_count   = 200,
    max_labels_count  = 200,
    max_boxes_count   = 100)

// ============================================================
// === INPUTS ===
// ============================================================

// ═══ ORB Range ═══
show_range = input.bool(true, "Show ORB Range Lines", group="═══ ORB Range ═══")

// ═══ FVG Detection ═══
show_fvg    = input.bool(true, "Show FVG Zones",               group="═══ FVG Detection ═══")
show_labels = input.bool(true, "Show Entry / SL / TP Labels",  group="═══ FVG Detection ═══")

// ═══ Entry & Exit ═══
entry_fib_pct = input.float(61.8, "Entry Fib Level %", options=[50.0, 61.8], group="═══ Entry & Exit ═══")
rr_ratio      = input.float(2.0,  "Risk:Reward Ratio", options=[1.5, 2.0, 3.0], group="═══ Entry & Exit ═══")
use_fib_tp    = input.bool(false,  "Use Fib 127% Extension as TP",              group="═══ Entry & Exit ═══")

// ═══ Filter Gate ═══
min_filters_required = input.int(1, "Min filters required to confirm bias (X of N)",
    minval=1, maxval=5,
    tooltip="Signal fires when at least X enabled filters agree on direction. X is auto-clamped to the number of enabled filters. Example: 3 enabled, X=2 → fires when 2 of 3 agree.",
    group="═══ Filter Gate ═══")

// Filter 1 — EMA
f1_active = input.bool(false, "Enable", group="Filter 1 — EMA", inline="f1h")
f1_show   = input.bool(true,  "Show",   group="Filter 1 — EMA", inline="f1h")
f1_fast   = input.int(50,  "EMA Fast",  group="Filter 1 — EMA", minval=1)
f1_slow   = input.int(200, "EMA Slow",  group="Filter 1 — EMA", minval=1)

// Filter 2 — MACD
f2_active  = input.bool(false, "Enable",      group="Filter 2 — MACD", inline="f2h")
f2_show    = input.bool(true,  "Show",        group="Filter 2 — MACD", inline="f2h")
f2_fast    = input.int(12,    "MACD Fast",    group="Filter 2 — MACD", minval=1)
f2_slow    = input.int(26,    "MACD Slow",    group="Filter 2 — MACD", minval=1)
f2_signal  = input.int(9,     "MACD Signal",  group="Filter 2 — MACD", minval=1)

// Filter 3 — RSI
f3_active     = input.bool(false, "Enable",                  group="Filter 3 — RSI", inline="f3h")
f3_show       = input.bool(true,  "Show",                    group="Filter 3 — RSI", inline="f3h")
f3_len        = input.int(21,    "RSI Period",               group="Filter 3 — RSI", minval=1)
f3_mid        = input.float(50,  "RSI Midline",              group="Filter 3 — RSI", minval=30, maxval=70)
f3_bull_floor = input.float(40,  "Pullback Floor (Bull)",    group="Filter 3 — RSI", minval=20, maxval=60)
f3_bear_ceil  = input.float(60,  "Pullback Ceiling (Bear)",  group="Filter 3 — RSI", minval=40, maxval=80)

// Filter 4 — ADX
f4_active    = input.bool(false, "Enable",       group="Filter 4 — ADX", inline="f4h")
f4_show      = input.bool(true,  "Show",         group="Filter 4 — ADX", inline="f4h")
f4_len       = input.int(14,    "ADX Period",    group="Filter 4 — ADX", minval=1)
f4_threshold = input.float(25,  "ADX Threshold", group="Filter 4 — ADX", minval=10, maxval=60)

// Filter 5 — VWAP
f5_active = input.bool(false, "Enable",  group="Filter 5 — VWAP", inline="f5h")
f5_show   = input.bool(true,  "Show",    group="Filter 5 — VWAP", inline="f5h")
f5_anchor = input.string("Session", "Anchor",
    options=["Session","Week","Month"], group="Filter 5 — VWAP")

// ═══ Display ═══
show_fib_levels = input.bool(true, "Show Fibonacci Levels", group="═══ Display ═══")
show_dashboard  = input.bool(true, "Show Filter Dashboard", group="═══ Display ═══")

// ============================================================
// === SHARED LOGIC: ORB RANGE ===
// ============================================================

// Timeframe guard — warn if chart TF > M15
tf_minutes  = timeframe.in_seconds() / 60
tf_too_high = tf_minutes > 15

if tf_too_high and barstate.islastconfirmedhistory
    label.new(bar_index, high, "⚠️ Apply on M1, M5, or M15 for correct ORB detection",
        style=label.style_label_center, color=color.orange, textcolor=color.white, size=size.normal)

// ORB window timestamps (America/New_York)
range_open  = timestamp("America/New_York", year, month, dayofmonth, 9, 30, 0)
range_close = timestamp("America/New_York", year, month, dayofmonth, 9, 44, 59)

in_orb_window = (time >= range_open) and (time <= range_close)

// Reset at each new day
var float orb_high = na
var float orb_low  = na

if ta.change(dayofweek) != 0
    orb_high := na
    orb_low  := na

// Accumulate across all bars inside the window
if in_orb_window and not tf_too_high
    orb_high := na(orb_high) ? high : math.max(orb_high, high)
    orb_low  := na(orb_low)  ? low  : math.min(orb_low,  low)

// Lock after window closes
orb_locked = not in_orb_window and not na(orb_high)

// Draw ORB lines — delete and redraw each session
var line orb_high_line = na
var line orb_low_line  = na
var label orb_high_lbl = na
var label orb_low_lbl  = na
var int   last_day_orb = na

if show_range and orb_locked and not tf_too_high
    current_day = dayofmonth
    if na(last_day_orb) or current_day != last_day_orb
        if not na(orb_high_line)
            line.delete(orb_high_line)
        if not na(orb_low_line)
            line.delete(orb_low_line)
        if not na(orb_high_lbl)
            label.delete(orb_high_lbl)
        if not na(orb_low_lbl)
            label.delete(orb_low_lbl)
        orb_high_line := line.new(bar_index, orb_high, bar_index, orb_high,
            extend=extend.right, color=#2196F3, width=2, style=line.style_solid)
        orb_low_line  := line.new(bar_index, orb_low,  bar_index, orb_low,
            extend=extend.right, color=#2196F3, width=2, style=line.style_solid)
        orb_high_lbl  := label.new(bar_index, orb_high, "09:30 High",
            style=label.style_label_right, color=#2196F3, textcolor=color.white, size=size.small)
        orb_low_lbl   := label.new(bar_index, orb_low,  "09:30 Low",
            style=label.style_label_right, color=#2196F3, textcolor=color.white, size=size.small)
        last_day_orb := current_day

// ============================================================
// === SHARED LOGIC: FVG DETECTION ===
// ============================================================

// Time filter: no signals after 12:00 EST
cutoff  = timestamp("America/New_York", year, month, dayofmonth, 12, 0, 0)
time_ok = time < cutoff

// One-signal-per-direction-per-day guards
var bool day_bull_fired = false
var bool day_bear_fired = false

if ta.change(dayofweek) != 0
    day_bull_fired := false
    day_bear_fired := false

// Track last 3 confirmed candles
c1_close = close[2]
c1_open  = open[2]
c1_high  = high[2]
c1_low   = low[2]

c2_close = close[1]
c2_open  = open[1]
c2_high  = high[1]
c2_low   = low[1]

c3_close = close
c3_open  = open
c3_high  = high
c3_low   = low

// Bullish FVG: 3-candle pattern piercing above orb_high
// Candle 1: body closes INSIDE range  (close <= orb_high)
// Candle 2: momentum candle breaks OUT above orb_high
// Candle 3: body closes OUTSIDE range (close > orb_high)
// Gap condition: c3_low > c1_high — this IS the FVG zone
fvg_bull_raw = (barstate.isconfirmed
    and orb_locked
    and not tf_too_high
    and time_ok
    and not day_bull_fired
    and not na(orb_high)
    and not na(orb_low)
    and (c1_close <= orb_high)
    and (c2_high  >  orb_high)
    and (c3_close >  orb_high)
    and (c3_low   >  c1_high))

// Bearish FVG: 3-candle pattern piercing below orb_low
// Candle 1: body closes INSIDE range  (close >= orb_low)
// Candle 2: momentum candle breaks OUT below orb_low
// Candle 3: body closes OUTSIDE range (close < orb_low)
// Gap condition: c3_high < c1_low — this IS the FVG zone
fvg_bear_raw = (barstate.isconfirmed
    and orb_locked
    and not tf_too_high
    and time_ok
    and not day_bear_fired
    and not na(orb_high)
    and not na(orb_low)
    and (c1_close >= orb_low)
    and (c2_low   <  orb_low)
    and (c3_close <  orb_low)
    and (c3_high  <  c1_low))

// FVG zone boundaries
fvg_bull_top    = c1_high
fvg_bull_bottom = c3_low
fvg_bear_top    = c3_high
fvg_bear_bottom = c1_low

// ============================================================
// === MODULAR FILTERS ===
// ============================================================

// --- Filter 1: Dual EMA ---
ema_fast = ta.ema(close, f1_fast)
ema_slow = ta.ema(close, f1_slow)

f1_long  = close > ema_fast and ema_fast > ema_slow
f1_short = close < ema_fast and ema_fast < ema_slow

// EMA visuals
plot(f1_show ? ema_fast : na, "EMA Fast", color=#FF9800, linewidth=1)
plot(f1_show ? ema_slow : na, "EMA Slow", color=#9C27B0, linewidth=1)

ema_golden_cross = ta.crossover(ema_fast,  ema_slow)
ema_death_cross  = ta.crossunder(ema_fast, ema_slow)

if f1_show and ema_golden_cross
    label.new(bar_index, low,  "GX", style=label.style_label_up,
        color=color.green, textcolor=color.white, size=size.tiny)
if f1_show and ema_death_cross
    label.new(bar_index, high, "DX", style=label.style_label_down,
        color=color.red,   textcolor=color.white, size=size.tiny)

// --- Filter 2: MACD Zero Line ---
[macd_line, signal_line, macd_hist] = ta.macd(close, f2_fast, f2_slow, f2_signal)

f2_long  = macd_line > 0
f2_short = macd_line < 0

// MACD background tint
bgcolor(f2_show and f2_long  ? color.new(color.green, 93) : na, title="MACD Bull BG")
bgcolor(f2_show and f2_short ? color.new(color.red,   93) : na, title="MACD Bear BG")

// --- Filter 3: RSI Momentum ---
rsi_val = ta.rsi(close, f3_len)

f3_long  = rsi_val >= f3_mid
f3_short = rsi_val <= f3_mid

f3_pullback_ok_long  = rsi_val >= f3_bull_floor
f3_pullback_ok_short = rsi_val <= f3_bear_ceil

// --- Filter 4: ADX Trend Strength ---
// NOTE: ADX alone cannot resolve direction — pair with at least one
// directional filter (EMA, MACD, RSI, or VWAP) for meaningful signals
[diplus, diminus, adx_val] = ta.dmi(f4_len, f4_len)

f4_long  = adx_val >= f4_threshold and diplus  > diminus
f4_short = adx_val >= f4_threshold and diminus > diplus

// --- Filter 5: VWAP ---
vwap_val = switch f5_anchor
    "Week"  => request.security(syminfo.tickerid, "W", ta.vwap(hlc3))
    "Month" => request.security(syminfo.tickerid, "M", ta.vwap(hlc3))
    =>         ta.vwap(hlc3)

f5_long  = close > vwap_val
f5_short = close < vwap_val

// VWAP line
plot(f5_show ? vwap_val : na, "VWAP", color=#E040FB, linewidth=1)

// ============================================================
// === FILTER GATE (X of N) ===
// ============================================================

// Count enabled filters
filters_enabled = ((f1_active ? 1 : 0)
                 + (f2_active ? 1 : 0)
                 + (f3_active ? 1 : 0)
                 + (f4_active ? 1 : 0)
                 + (f5_active ? 1 : 0))

// Count directional votes from enabled filters only
votes_long = ((f1_active and f1_long  ? 1 : 0)
            + (f2_active and f2_long  ? 1 : 0)
            + (f3_active and f3_long  ? 1 : 0)
            + (f4_active and f4_long  ? 1 : 0)
            + (f5_active and f5_long  ? 1 : 0))

votes_short = ((f1_active and f1_short ? 1 : 0)
             + (f2_active and f2_short ? 1 : 0)
             + (f3_active and f3_short ? 1 : 0)
             + (f4_active and f4_short ? 1 : 0)
             + (f5_active and f5_short ? 1 : 0))

// Clamp X — never require more than filters_enabled
effective_min = math.min(min_filters_required, filters_enabled)

// INDEPENDENT evaluation — no coupling between directions
// bias_long and bias_short can BOTH be true simultaneously — this is valid
// Example 1: 5 active | 4 long, 1 short | X=2
//   votes_long=4  >= 2 → bias_long=true  (buy  OPEN)
//   votes_short=1 <  2 → bias_short=false (sell BLOCKED)
// Example 2: 4 active | 2 long, 2 short | X=2
//   votes_long=2  >= 2 → bias_long=true  (buy  OPEN)
//   votes_short=2 >= 2 → bias_short=true (sell OPEN) → whichever FVG forms triggers its trade
// Example 3: 3 active | 1 long, 2 short | X=2
//   votes_long=1  <  2 → bias_long=false (buy  BLOCKED)
//   votes_short=2 >= 2 → bias_short=true (sell OPEN)
// Example 4: 0 active
//   filters_enabled=0 → bias_long=true, bias_short=true (passthrough)
bias_long  = filters_enabled == 0 or votes_long  >= effective_min
bias_short = filters_enabled == 0 or votes_short >= effective_min

// ============================================================
// === FIBONACCI ENTRY ===
// ============================================================

var float bull_swing_low   = na
var float bull_swing_high  = na
var float bear_swing_high  = na
var float bear_swing_low   = na

// Valid entry signals (FVG + bias + time)
valid_long_entry  = fvg_bull_raw and bias_long
valid_short_entry = fvg_bear_raw and bias_short

// Capture swing points on valid signal
if valid_long_entry
    bull_swing_low  := c1_low
    bull_swing_high := c2_high
    day_bull_fired  := true

if valid_short_entry
    bear_swing_high := c1_high
    bear_swing_low  := c2_low
    day_bear_fired  := true

// --- Bullish Fibonacci ---
bull_fib_range = bull_swing_high - bull_swing_low

bull_fib_0    = bull_swing_high
bull_fib_50   = bull_swing_high - bull_fib_range * 0.500
bull_fib_618  = bull_swing_high - bull_fib_range * 0.618
bull_fib_786  = bull_swing_high - bull_fib_range * 0.786
bull_fib_127  = bull_swing_high + bull_fib_range * 0.270

entry_price_long = bull_swing_high - bull_fib_range * (entry_fib_pct / 100)

// SL: just below fib_786 OR below candle1 wick — whichever is lower
sl_long = math.min(bull_fib_786, c1_low) - syminfo.mintick * 2

// TP
tp_rr_long    = entry_price_long + (entry_price_long - sl_long) * rr_ratio
tp_fib_long   = bull_fib_127
tp_final_long = use_fib_tp ? tp_fib_long : tp_rr_long

// --- Bearish Fibonacci ---
bear_fib_range = bear_swing_high - bear_swing_low

bear_fib_0    = bear_swing_low
bear_fib_50   = bear_swing_low  + bear_fib_range * 0.500
bear_fib_618  = bear_swing_low  + bear_fib_range * 0.618
bear_fib_786  = bear_swing_low  + bear_fib_range * 0.786
bear_fib_127  = bear_swing_low  - bear_fib_range * 0.270

entry_price_short = bear_swing_low + bear_fib_range * (entry_fib_pct / 100)

// SL: just above fib_786 OR above candle1 wick — whichever is higher
sl_short = math.max(bear_fib_786, c1_high) + syminfo.mintick * 2

// TP
tp_rr_short    = entry_price_short - (entry_price_short - sl_short) * rr_ratio
tp_fib_short   = bear_fib_127
tp_final_short = use_fib_tp ? tp_fib_short : tp_rr_short

// ============================================================
// === EXECUTION ===
// ============================================================

// Entry — independent per direction, no suppression when both biases true
// (RULE 1: bias_long and bias_short can both be true — FVG resolves direction)
if valid_long_entry and not tf_too_high
    strategy.entry("Long", strategy.long, limit=entry_price_long,
        comment="SMC Long | Fib:" + str.tostring(entry_fib_pct) +
                "% | Votes:" + str.tostring(votes_long) +
                "/" + str.tostring(filters_enabled))

if valid_short_entry and not tf_too_high
    strategy.entry("Short", strategy.short, limit=entry_price_short,
        comment="SMC Short | Fib:" + str.tostring(entry_fib_pct) +
                "% | Votes:" + str.tostring(votes_short) +
                "/" + str.tostring(filters_enabled))

// Exit — SL and TP per position
strategy.exit("Long Exit",  from_entry="Long",
    stop=sl_long,   limit=tp_final_long)
strategy.exit("Short Exit", from_entry="Short",
    stop=sl_short,  limit=tp_final_short)

// Cancel pending limit orders not filled by 12:00 EST
if time >= cutoff and strategy.opentrades == 0
    strategy.cancel("Long")
    strategy.cancel("Short")

// RSI pullback gate — cancel pending long/short if pullback health breached before fill
// (only when Filter 3 is active and position not yet open)
if f3_active and strategy.opentrades == 0
    if not f3_pullback_ok_long
        strategy.cancel("Long")
    if not f3_pullback_ok_short
        strategy.cancel("Short")

// ============================================================
// === VISUALS (Strategy file: FVG zones, Fib levels, labels, dashboard) ===
// ============================================================

// ---- FVG Box drawing ----
var box fvg_bull_box = na
var box fvg_bear_box = na

if show_fvg and valid_long_entry
    if not na(fvg_bull_box)
        box.delete(fvg_bull_box)
    fvg_bull_box := box.new(bar_index - 2, fvg_bull_top, bar_index + 20, fvg_bull_bottom,
        border_color=color.new(#00E676, 0), bgcolor=color.new(#00E676, 80), border_width=1)

if show_fvg and valid_short_entry
    if not na(fvg_bear_box)
        box.delete(fvg_bear_box)
    fvg_bear_box := box.new(bar_index - 2, fvg_bear_top, bar_index + 20, fvg_bear_bottom,
        border_color=color.new(#FF5252, 0), bgcolor=color.new(#FF5252, 80), border_width=1)

// FVG candle markers
if show_fvg and valid_long_entry
    label.new(bar_index, low,  "▲", style=label.style_label_up,
        color=color.new(#00E676, 60), textcolor=#00E676, size=size.small)
if show_fvg and valid_short_entry
    label.new(bar_index, high, "▼", style=label.style_label_down,
        color=color.new(#FF5252, 60), textcolor=#FF5252, size=size.small)

// ---- Fibonacci levels — bull ----
var line fib_bull_50_line    = na
var line fib_bull_618_line   = na
var line fib_bull_786_line   = na
var line fib_bull_127_line   = na
var box  fib_bull_zone_box   = na
var line fib_bull_entry_line = na
var line fib_bull_sl_line    = na
var line fib_bull_tp_line    = na

if valid_long_entry
    line.delete(fib_bull_50_line)
    line.delete(fib_bull_618_line)
    line.delete(fib_bull_786_line)
    line.delete(fib_bull_127_line)
    box.delete(fib_bull_zone_box)
    line.delete(fib_bull_entry_line)
    line.delete(fib_bull_sl_line)
    line.delete(fib_bull_tp_line)

    if show_fib_levels
        fib_bull_50_line  := line.new(bar_index, bull_fib_50,  bar_index, bull_fib_50,
            extend=extend.right, color=#888888, style=line.style_dashed, width=1)
        fib_bull_618_line := line.new(bar_index, bull_fib_618, bar_index, bull_fib_618,
            extend=extend.right, color=#00BCD4, style=line.style_dashed, width=1)
        fib_bull_786_line := line.new(bar_index, bull_fib_786, bar_index, bull_fib_786,
            extend=extend.right, color=#FF5252, style=line.style_dashed, width=1)
        fib_bull_127_line := line.new(bar_index, bull_fib_127, bar_index, bull_fib_127,
            extend=extend.right, color=#69F0AE, style=line.style_dashed, width=1)
        fib_bull_zone_box := box.new(bar_index, bull_fib_50, bar_index + 30, bull_fib_618,
            border_color=color.new(#00BCD4, 80), bgcolor=color.new(#00BCD4, 88))

        label.new(bar_index, bull_fib_50,  "50%",           style=label.style_label_right, color=#888888, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bull_fib_618, "61.8% — Entry", style=label.style_label_right, color=#00BCD4, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bull_fib_786, "78.6% — SL",    style=label.style_label_right, color=#FF5252, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bull_fib_127, "127% — Ext TP", style=label.style_label_right, color=#69F0AE, textcolor=color.white, size=size.tiny)

    if show_labels
        fib_bull_entry_line := line.new(bar_index, entry_price_long, bar_index, entry_price_long,
            extend=extend.right, color=color.gray, style=line.style_dashed, width=1)
        fib_bull_sl_line    := line.new(bar_index, sl_long,          bar_index, sl_long,
            extend=extend.right, color=#FF5252,    style=line.style_dashed, width=1)
        fib_bull_tp_line    := line.new(bar_index, tp_final_long,    bar_index, tp_final_long,
            extend=extend.right, color=#00E676,    style=line.style_dashed, width=1)
        label.new(bar_index, entry_price_long, "Entry", style=label.style_label_right, color=color.gray, textcolor=color.white, size=size.small)
        label.new(bar_index, sl_long,          "SL",    style=label.style_label_right, color=#FF5252,    textcolor=color.white, size=size.small)
        label.new(bar_index, tp_final_long,    "TP",    style=label.style_label_right, color=#00E676,    textcolor=color.white, size=size.small)

// ---- Fibonacci levels — bear ----
var line fib_bear_50_line    = na
var line fib_bear_618_line   = na
var line fib_bear_786_line   = na
var line fib_bear_127_line   = na
var box  fib_bear_zone_box   = na
var line fib_bear_entry_line = na
var line fib_bear_sl_line    = na
var line fib_bear_tp_line    = na

if valid_short_entry
    line.delete(fib_bear_50_line)
    line.delete(fib_bear_618_line)
    line.delete(fib_bear_786_line)
    line.delete(fib_bear_127_line)
    box.delete(fib_bear_zone_box)
    line.delete(fib_bear_entry_line)
    line.delete(fib_bear_sl_line)
    line.delete(fib_bear_tp_line)

    if show_fib_levels
        fib_bear_50_line  := line.new(bar_index, bear_fib_50,  bar_index, bear_fib_50,
            extend=extend.right, color=#888888, style=line.style_dashed, width=1)
        fib_bear_618_line := line.new(bar_index, bear_fib_618, bar_index, bear_fib_618,
            extend=extend.right, color=#00BCD4, style=line.style_dashed, width=1)
        fib_bear_786_line := line.new(bar_index, bear_fib_786, bar_index, bear_fib_786,
            extend=extend.right, color=#FF5252, style=line.style_dashed, width=1)
        fib_bear_127_line := line.new(bar_index, bear_fib_127, bar_index, bear_fib_127,
            extend=extend.right, color=#69F0AE, style=line.style_dashed, width=1)
        fib_bear_zone_box := box.new(bar_index, bear_fib_618, bar_index + 30, bear_fib_50,
            border_color=color.new(#00BCD4, 80), bgcolor=color.new(#00BCD4, 88))

        label.new(bar_index, bear_fib_50,  "50%",           style=label.style_label_right, color=#888888, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bear_fib_618, "61.8% — Entry", style=label.style_label_right, color=#00BCD4, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bear_fib_786, "78.6% — SL",    style=label.style_label_right, color=#FF5252, textcolor=color.white, size=size.tiny)
        label.new(bar_index, bear_fib_127, "127% — Ext TP", style=label.style_label_right, color=#69F0AE, textcolor=color.white, size=size.tiny)

    if show_labels
        fib_bear_entry_line := line.new(bar_index, entry_price_short, bar_index, entry_price_short,
            extend=extend.right, color=color.gray, style=line.style_dashed, width=1)
        fib_bear_sl_line    := line.new(bar_index, sl_short,          bar_index, sl_short,
            extend=extend.right, color=#FF5252,    style=line.style_dashed, width=1)
        fib_bear_tp_line    := line.new(bar_index, tp_final_short,    bar_index, tp_final_short,
            extend=extend.right, color=#00E676,    style=line.style_dashed, width=1)
        label.new(bar_index, entry_price_short, "Entry", style=label.style_label_right, color=color.gray, textcolor=color.white, size=size.small)
        label.new(bar_index, sl_short,          "SL",    style=label.style_label_right, color=#FF5252,    textcolor=color.white, size=size.small)
        label.new(bar_index, tp_final_short,    "TP",    style=label.style_label_right, color=#00E676,    textcolor=color.white, size=size.small)

// ---- Filter Status Dashboard ----
c_header = color.new(color.gray,  20)
c_green  = color.new(color.green, 20)
c_red    = color.new(color.red,   20)
c_dark   = color.new(#1E1E2E,     0)
c_dim    = color.new(color.gray,  60)
c_txt_w  = color.white
c_txt_g  = color.new(color.gray,  30)

_filter_cell(col, active, votes) =>
    if not active
        [c_dim, "—"]
    else if votes
        [c_green, "✓"]
    else
        [c_dark, "✗"]

var table dash = na

if show_dashboard
    if na(dash)
        dash := table.new(position.top_right, 3, 11,
            border_color=color.gray, border_width=1, frame_color=color.gray, frame_width=1)

    table.cell(dash, 0, 0, "Filter", bgcolor=c_header, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 0, "Long",   bgcolor=c_header, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 0, "Short",  bgcolor=c_header, text_color=c_txt_w, text_size=size.small)

    [f1l_c, f1l_t] = _filter_cell(1, f1_active, f1_long)
    [f1s_c, f1s_t] = _filter_cell(2, f1_active, f1_short)
    table.cell(dash, 0, 1, "EMA",  bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 1, f1l_t, bgcolor=f1l_c,  text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 1, f1s_t, bgcolor=f1s_c,  text_color=c_txt_w, text_size=size.small)

    [f2l_c, f2l_t] = _filter_cell(1, f2_active, f2_long)
    [f2s_c, f2s_t] = _filter_cell(2, f2_active, f2_short)
    table.cell(dash, 0, 2, "MACD", bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 2, f2l_t, bgcolor=f2l_c,  text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 2, f2s_t, bgcolor=f2s_c,  text_color=c_txt_w, text_size=size.small)

    [f3l_c, f3l_t] = _filter_cell(1, f3_active, f3_long)
    [f3s_c, f3s_t] = _filter_cell(2, f3_active, f3_short)
    table.cell(dash, 0, 3, "RSI(" + str.tostring(f3_len) + ")", bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 3, f3l_t, bgcolor=f3l_c, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 3, f3s_t, bgcolor=f3s_c, text_color=c_txt_w, text_size=size.small)

    [f4l_c, f4l_t] = _filter_cell(1, f4_active, f4_long)
    [f4s_c, f4s_t] = _filter_cell(2, f4_active, f4_short)
    table.cell(dash, 0, 4, "ADX",  bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 4, f4l_t, bgcolor=f4l_c,  text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 4, f4s_t, bgcolor=f4s_c,  text_color=c_txt_w, text_size=size.small)

    [f5l_c, f5l_t] = _filter_cell(1, f5_active, f5_long)
    [f5s_c, f5s_t] = _filter_cell(2, f5_active, f5_short)
    table.cell(dash, 0, 5, "VWAP", bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 5, f5l_t, bgcolor=f5l_c,  text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 5, f5s_t, bgcolor=f5s_c,  text_color=c_txt_w, text_size=size.small)

    table.cell(dash, 0, 6, "─────────────────", bgcolor=c_header, text_color=c_txt_g, text_size=size.tiny)
    table.cell(dash, 1, 6, "─────",             bgcolor=c_header, text_color=c_txt_g, text_size=size.tiny)
    table.cell(dash, 2, 6, "─────",             bgcolor=c_header, text_color=c_txt_g, text_size=size.tiny)

    table.cell(dash, 0, 7, "Votes",                    bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(votes_long),   bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 7, str.tostring(votes_short),  bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)

    table.cell(dash, 0, 8, "Required (X/N)",
        bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(effective_min) + "/" + str.tostring(filters_enabled),
        bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 8, str.tostring(effective_min) + "/" + str.tostring(filters_enabled),
        bgcolor=c_dark, text_color=c_txt_w, text_size=size.small)

    bias_long_txt   = filters_enabled == 0 ? "NO FILTER" : bias_long  ? "✓ OPEN" : "✗ BLOCKED"
    bias_long_color = filters_enabled == 0 ? c_dim       : bias_long  ? c_green  : c_dim
    table.cell(dash, 0, 9, "Bias Long",    bgcolor=c_dark,       text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 9, bias_long_txt,  bgcolor=bias_long_color, text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 9, "",             bgcolor=c_dark,       text_color=c_txt_w, text_size=size.small)

    bias_short_txt   = filters_enabled == 0 ? "NO FILTER" : bias_short  ? "✓ OPEN" : "✗ BLOCKED"
    bias_short_color = filters_enabled == 0 ? c_dim        : bias_short  ? c_red   : c_dim
    table.cell(dash, 0, 10, "Bias Short",    bgcolor=c_dark,         text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 1, 10, "",              bgcolor=c_dark,         text_color=c_txt_w, text_size=size.small)
    table.cell(dash, 2, 10, bias_short_txt,  bgcolor=bias_short_color, text_color=c_txt_w, text_size=size.small)
