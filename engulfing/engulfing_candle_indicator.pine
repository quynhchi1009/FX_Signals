//@version=6
// Matches strategy logic; calc_on_every_tick=false. Use regular candles for best alignment with live prices.
indicator("Engulfing Indicator", overlay=true, calc_on_every_tick=false, max_labels_count=500, max_boxes_count=500, max_lines_count=500)

// === INPUTS ===

// === DISPLAY ===
grpDisp = "DISPLAY"
show_sl_tp = input.bool(true, "Show SL/TP Lines", tooltip="Dashed SL (red) and TP (green); TP uses R multiple below.", group=grpDisp)
tp_r_multiple = input.float(3.0, "TP line (R multiple)", minval=0.1, step=0.1, tooltip="Must match strategy take-profit R for consistent lines.", group=grpDisp)
line_extend_bars = input.int(10, "SL/TP Line Length (bars)", minval=1, maxval=500, tooltip="Horizontal segment length from signal bar.", group=grpDisp)
show_table = input.bool(true, "Show Filter Status Table", tooltip="Top-right filter status.", group=grpDisp)

// === ENGULFING ===
grpEng = "ENGULFING"
is_forex = input.bool(true, "Forex pip mode", tooltip="If true, 1 pip = syminfo.mintick × 10. If false, 1 pip = syminfo.mintick.", group=grpEng)
min_body_filter_enabled = input.bool(false, "Enable minimum body (pips)", tooltip="When off, body size in pips is not filtered.", group=grpEng)
min_candle_pips = input.float(5.0, "Minimum body (pips)", minval=0.0, step=0.1, group=grpEng, active=min_body_filter_enabled)

// === EMA FILTER ===
grpEma = "EMA FILTER"
ema_filter_enabled = input.bool(false, "Enable EMA filter", tooltip="When off, EMA alignment is not required.", group=grpEma)
ema_fast_len = input.int(20, "Fast EMA length", minval=1, group=grpEma, active=ema_filter_enabled)
ema_slow_len = input.int(50, "Slow EMA length", minval=1, group=grpEma, active=ema_filter_enabled)

// === ATR FILTER ===
grpAtr = "ATR FILTER"
atr_filter_enabled = input.bool(true, "Enable ATR filter", group=grpAtr)
atr_len = input.int(14, "ATR length", minval=1, group=grpAtr, active=atr_filter_enabled)
atr_multiplier = input.float(1.5, "ATR multiplier (max range)", minval=0.01, step=0.1, tooltip="Pass when range ≤ ATR × mult.", group=grpAtr, active=atr_filter_enabled)

// === TREND BIAS ===
grpTrend = "TREND BIAS"
trend_filter_enabled = input.bool(true, "Enable trend bias filter", group=grpTrend)
pivot_len = input.int(3, "Bias pivot length", minval=1, maxval=50, tooltip="Bars for pivots; bias uses last 2 highs and 2 lows.", group=grpTrend, active=trend_filter_enabled)

// === SESSION FILTER ===
grpSess = "SESSION FILTER"
session_filter_enabled = input.bool(true, "Block 22:45–23:15 UTC", group=grpSess)

// --- drawing helpers
f_store_box(array<box> arr, box b) =>
    array.push(arr, b)
    while array.size(arr) > 498
        box.delete(array.get(arr, 0))
        array.remove(arr, 0)

f_store_two_lines(array<line> arr, line l1, line l2) =>
    array.push(arr, l1)
    array.push(arr, l2)
    while array.size(arr) > 498
        line.delete(array.get(arr, 0))
        array.remove(arr, 0)

// === CALCULATIONS ===

pip_size = is_forex ? syminfo.mintick * 10.0 : syminfo.mintick

h_utc = hour(time, "UTC")
m_utc = minute(time, "UTC")
tod_utc = h_utc * 60 + m_utc
session_blocked = session_filter_enabled and tod_utc >= (22 * 60 + 45) and tod_utc <= (23 * 60 + 15)

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
atr_val = ta.atr(atr_len)

h1 = high[1]
l1 = low[1]
prev_open = open[1]
prev_close = close[1]
prev_body_high = math.max(prev_open, prev_close)
prev_body_low = math.min(prev_open, prev_close)

body = math.abs(close - open)
upper_wick = high - math.max(close, open)
lower_wick = math.min(close, open) - low
wick_ok = body > 0 and upper_wick < body and lower_wick < body

bear_eng = high >= h1 and low <= l1 and close < prev_body_low and wick_ok
bull_eng = high >= h1 and low <= l1 and close > prev_body_high and wick_ok

body_pips = body / pip_size
min_body_ok = body_pips >= min_candle_pips

candle_range = high - low
atr_ok = not na(atr_val) and candle_range <= atr_multiplier * atr_val
atr_pass = not atr_filter_enabled or atr_ok

ema_buy_ok = ema_fast > ema_slow
ema_sell_ok = ema_fast < ema_slow

var float last_high1 = na
var float last_high2 = na
var float last_low1 = na
var float last_low2 = na

ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

if not na(ph)
    last_high2 := last_high1
    last_high1 := ph

if not na(pl)
    last_low2 := last_low1
    last_low1 := pl

buy_bias = not na(last_high1) and not na(last_high2) and not na(last_low1) and not na(last_low2) and last_high1 > last_high2 and last_low1 > last_low2
sell_bias = not na(last_high1) and not na(last_high2) and not na(last_low1) and not na(last_low2) and last_high1 < last_high2 and last_low1 < last_low2

all_core_filters_on = ema_filter_enabled and atr_filter_enabled and trend_filter_enabled
min_bars_all = math.max(ema_slow_len, atr_len, pivot_len * 2 + 1) + 5
bars_ok = not all_core_filters_on or (bar_index >= min_bars_all and not na(atr_val))

filter_ok = not session_blocked and bars_ok and (not min_body_filter_enabled or min_body_ok) and atr_pass

sl_dist_long = close - low
sl_dist_short = high - close

session_table_ok = not session_blocked
trend_table_txt = trend_filter_enabled ? (buy_bias ? "BUY" : sell_bias ? "SELL" : "NONE") : "OFF"
ema_table_ok = ema_buy_ok or ema_sell_ok
atr_table_ok = not na(atr_val) and atr_ok
bars_table_ok = bars_ok

// === SIGNALS ===

bullish_signal = bull_eng and filter_ok and (not ema_filter_enabled or ema_buy_ok) and (not trend_filter_enabled or buy_bias)
bearish_signal = bear_eng and filter_ok and (not ema_filter_enabled or ema_sell_ok) and (not trend_filter_enabled or sell_bias)

// === VISUALS ===

var array<box> box_store = array.new_box()
var array<line> line_store = array.new_line()
var table info_tbl = na

if not show_sl_tp
    while array.size(line_store) > 0
        line.delete(array.pop(line_store))

barcolor(bullish_signal ? color.new(#00E676, 0) : bearish_signal ? color.new(#FF1744, 0) : na)

plotshape(bullish_signal, title="Buy Arrow", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(bearish_signal, title="Sell Arrow", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal)

if bullish_signal
    label.new(bar_index, low, "ENG BUY", style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.small)
    nb = box.new(bar_index, high, bar_index, low, xloc=xloc.bar_index, border_color=color.new(color.green, 0), bgcolor=color.new(color.green, 85), border_width=2)
    f_store_box(box_store, nb)
    if show_sl_tp
        x_r = bar_index + line_extend_bars
        tp_px = close + tp_r_multiple * sl_dist_long
        ls = line.new(bar_index, low, x_r, low, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.red, 0), style=line.style_dashed, width=1)
        lt = line.new(bar_index, tp_px, x_r, tp_px, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.green, 0), style=line.style_dashed, width=1)
        f_store_two_lines(line_store, ls, lt)

if bearish_signal
    label.new(bar_index, high, "ENG SELL", style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.small)
    nb = box.new(bar_index, high, bar_index, low, xloc=xloc.bar_index, border_color=color.new(color.red, 0), bgcolor=color.new(color.red, 85), border_width=2)
    f_store_box(box_store, nb)
    if show_sl_tp
        x_r = bar_index + line_extend_bars
        tp_px = close - tp_r_multiple * sl_dist_short
        ls = line.new(bar_index, high, x_r, high, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.red, 0), style=line.style_dashed, width=1)
        lt = line.new(bar_index, tp_px, x_r, tp_px, xloc=xloc.bar_index, extend=extend.none, color=color.new(color.green, 0), style=line.style_dashed, width=1)
        f_store_two_lines(line_store, ls, lt)

plot(ema_fast, title="EMA Fast", color=color.orange, linewidth=1)
plot(ema_slow, title="EMA Slow", color=color.blue, linewidth=2)

if show_table
    if na(info_tbl)
        info_tbl := table.new(position.top_right, 2, 7, border_width=1, frame_color=color.new(color.gray, 30), bgcolor=color.new(color.black, 75))
    table.cell(info_tbl, 0, 0, "Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60))
    table.cell(info_tbl, 1, 0, "Status", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60))

    table.cell(info_tbl, 0, 1, "Session OK", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    table.cell(info_tbl, 1, 1, session_table_ok ? "✅" : "❌", text_color=color.white, text_size=size.small, bgcolor=session_table_ok ? color.new(color.green, 70) : color.new(color.red, 70))

    table.cell(info_tbl, 0, 2, "Bars OK", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    bars_stat = not all_core_filters_on ? "N/A" : bars_table_ok ? "✅" : "❌"
    bars_bg = not all_core_filters_on ? color.new(color.gray, 75) : bars_table_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 2, bars_stat, text_color=color.white, text_size=size.small, bgcolor=bars_bg)

    table.cell(info_tbl, 0, 3, "Trend Bias", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    trend_bg = not trend_filter_enabled ? color.new(color.gray, 75) : buy_bias ? color.new(color.green, 70) : sell_bias ? color.new(color.red, 70) : color.new(color.gray, 70)
    table.cell(info_tbl, 1, 3, trend_table_txt, text_color=color.white, text_size=size.small, bgcolor=trend_bg)

    table.cell(info_tbl, 0, 4, "EMA Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    ema_stat = not ema_filter_enabled ? "OFF" : ema_table_ok ? "✅" : "❌"
    ema_bg = not ema_filter_enabled ? color.new(color.gray, 75) : ema_table_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 4, ema_stat, text_color=color.white, text_size=size.small, bgcolor=ema_bg)

    table.cell(info_tbl, 0, 5, "ATR Filter", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    atr_stat = not atr_filter_enabled ? "OFF" : atr_table_ok ? "✅" : "❌"
    atr_bg = not atr_filter_enabled ? color.new(color.gray, 75) : atr_table_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 5, atr_stat, text_color=color.white, text_size=size.small, bgcolor=atr_bg)

    table.cell(info_tbl, 0, 6, "Min body", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 80))
    min_stat = not min_body_filter_enabled ? "OFF" : min_body_ok ? "✅" : "❌"
    min_bg = not min_body_filter_enabled ? color.new(color.gray, 75) : min_body_ok ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(info_tbl, 1, 6, min_stat, text_color=color.white, text_size=size.small, bgcolor=min_bg)
else
    if not na(info_tbl)
        table.delete(info_tbl)
        info_tbl := na
