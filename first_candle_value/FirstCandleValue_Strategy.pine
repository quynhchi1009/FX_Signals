//@version=6
strategy("First Candle Value [Strategy] — Opening M15 Lines",
     overlay                   = true,
     pyramiding                = 0,
     calc_on_every_tick        = false,
     process_orders_on_close   = true,
     initial_capital           = 100000,
     default_qty_type          = strategy.percent_of_equity,
     default_qty_value         = 1,
     commission_type           = strategy.commission.percent,
     commission_value          = 0.0,
     slippage                  = 0,
     max_lines_count           = 500,
     max_labels_count          = 500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════
string G_SESS = "Session & opening range"
string G_ENT  = "Entries"
string G_SL   = "Stop loss"
string G_TP   = "Take profit"
string G_TR   = "Trailing"
string G_RISK = "Risk management"
string G_VIS  = "Visuals"

i_sess          = input.session("0930-1600", "New York session", group=G_SESS)
i_tz            = input.string("America/New_York", "Session timezone", group=G_SESS)
i_strictRev     = input.bool(false, "Stricter reversal (prior close outside range)", group=G_SESS,
     tooltip="Opening high/low = first M15 candle of this session (e.g. 09:30–09:45 NY). Use M1/M5/M15 chart; backtest on M15.")

i_useBO         = input.bool(true, "Trade breakouts", group=G_ENT)
i_useRev        = input.bool(true, "Trade reversals", group=G_ENT)
i_long          = input.bool(true, "Allow longs", group=G_ENT)
i_short         = input.bool(true, "Allow shorts", group=G_ENT)

i_slMode        = input.string("First candle", "Stop mode", group=G_SL,
     options=["Opposite VA", "First candle", "Signal bar", "Retest candle", "ATR"])
i_atrLen        = input.int(14, "ATR length (ATR stop)", minval=1, group=G_SL)
i_atrStopM      = input.float(1.5, "ATR × (stop distance)", minval=0.1, step=0.1, group=G_SL)
i_slBuffer      = input.float(0.0, "Extra stop buffer (× mintick)", minval=0.0, step=1.0, group=G_SL)

i_tpMode        = input.string("Fixed R multiple", "Take-profit mode", group=G_TP,
     options=["Fixed R multiple", "Opposite first candle", "Trailing only", "Partial R + trail"])
i_tpR           = input.float(2.0, "TP: R multiple (full or first leg)", minval=0.1, step=0.1, group=G_TP)
i_partialPct    = input.float(50.0, "Partial exit % of position", minval=5.0, maxval=95.0, step=5.0, group=G_TP)
i_partialR      = input.float(1.0, "Partial at R", minval=0.1, step=0.1, group=G_TP)

i_trailOn       = input.bool(true, "Use trailing", group=G_TR)
i_trailMode     = input.string("Previous candle", "Trail mode", group=G_TR,
     options=["Off", "Previous candle", "Swing window", "ATR"])
i_swingLB       = input.int(5, "Swing trail: lookback bars", minval=2, maxval=100, group=G_TR)
i_trailAtrM     = input.float(1.0, "ATR trail ×", minval=0.1, step=0.1, group=G_TR)
i_trailBuf      = input.float(0.0, "Trail buffer (× mintick)", minval=0.0, step=1.0, group=G_TR)

i_beR           = input.float(1.0, "Move stop to breakeven after +R (0 = off)", minval=0.0, step=0.1, group=G_RISK)
i_onePerDir     = input.bool(true, "One trade per direction per session", group=G_RISK)
i_oneTotal      = input.bool(false, "One trade total per session", group=G_RISK)

i_showOpenLines = input.bool(true, "Show opening M15 high/low lines", group=G_VIS)
i_showLbl       = input.bool(true, "Show entry labels", group=G_VIS)
i_showTfWarn    = input.bool(true, "Show timeframe warning label", group=G_VIS)

i_colHigh       = input.color(color.new(color.yellow, 0), "Opening high line", group=G_VIS)
i_colLow        = input.color(color.new(color.silver, 0), "Opening low line", group=G_VIS)
i_colWarn       = input.color(color.new(color.red, 0), "Warning color", group=G_VIS)

// ══════════════════════════════════════════════════════════════════════════════
// TIMEFRAME RULES
// - Lines: M1, M5, M15 (chart period ≤ 15m)
// - Strategy entries / exits: M15 only (matches “first M15 candle” backtest)
// - Charts > M15: warning table + tint; logic does not run
// ══════════════════════════════════════════════════════════════════════════════
float chartSec   = timeframe.in_seconds()
float m15Sec     = timeframe.in_seconds("15")

bool inSess      = not na(time(timeframe.period, i_sess, i_tz))
bool newSess     = inSess and not inSess[1]

bool tfDisplayOk = timeframe.isintraday and chartSec > 0 and chartSec <= m15Sec
bool tfTradeOk   = timeframe.isintraday and chartSec == m15Sec
bool scriptActive = tfDisplayOk

float atrV = ta.atr(i_atrLen)
float buf  = i_slBuffer * syminfo.mintick
float tbuf = i_trailBuf * syminfo.mintick

// Trailing anchors — computed every bar (inline series; strategy() must not call user fns only inside branches — CW10003).
float trailFloorLong = -1e100
float trailCeilShort = 1e100
if i_trailOn
    if i_trailMode == "Previous candle"
        trailFloorLong := low[1] - tbuf
        trailCeilShort := high[1] + tbuf
    else if i_trailMode == "Swing window"
        trailFloorLong := ta.lowest(low, i_swingLB)[1] - tbuf
        trailCeilShort := ta.highest(high, i_swingLB)[1] + tbuf
    else if i_trailMode == "ATR"
        trailFloorLong := close - atrV * i_trailAtrM
        trailCeilShort := close + atrV * i_trailAtrM

// First NY-session 15m slot (e.g. 09:30 bar) — always 15m, independent of chart TF
int openBucketTime = time("15", i_sess, i_tz)
bool inOpenBucket  = not na(openBucketTime)

// ══════════════════════════════════════════════════════════════════════════════
// OPENING M15 RANGE STATE
// ══════════════════════════════════════════════════════════════════════════════
var int   firstBucketTime = na
var bool  firstBucketLocked = false
var bool  sessRangeReady = false

var float accH = na
var float accL = na
var float fcHigh = na
var float fcLow  = na

var line  openHighLine = na
var line  openLowLine  = na
var table tfWarnTable  = na

f_deleteLine(line ln) =>
    if not na(ln)
        line.delete(ln)

// ══════════════════════════════════════════════════════════════════════════════
// TIMEFRAME WARNING (table + chart tint) — TF > M15 or non-intraday
// ══════════════════════════════════════════════════════════════════════════════
bgcolor(i_showTfWarn and not tfDisplayOk ? color.new(i_colWarn, 93) : na, title="TF guard")

if barstate.islast and i_showTfWarn
    if not tfDisplayOk
        if na(tfWarnTable)
            tfWarnTable := table.new(position.top_right, 1, 4, border_width=1, frame_color=i_colWarn,
                 bgcolor=color.new(color.black, 75))
        table.cell(tfWarnTable, 0, 0, "First Candle Value", text_color=color.white, text_size=size.normal)
        table.cell(tfWarnTable, 0, 1, "Switch to M1, M5, or M15", text_color=color.white, text_size=size.small)
        table.cell(tfWarnTable, 0, 2, "Lines = first NY M15 high/low", text_color=color.new(color.silver, 0), text_size=size.small)
        table.cell(tfWarnTable, 0, 3, "Strategy Tester: chart M15", text_color=color.new(color.silver, 0), text_size=size.small)
    else if not na(tfWarnTable)
        table.delete(tfWarnTable)
        tfWarnTable := na

// ══════════════════════════════════════════════════════════════════════════════
// SESSION RESET
// ══════════════════════════════════════════════════════════════════════════════
if newSess and scriptActive
    firstBucketTime   := openBucketTime
    firstBucketLocked := false
    sessRangeReady    := false

    accH := na
    accL := na
    fcHigh := na
    fcLow  := na

    f_deleteLine(openHighLine)
    f_deleteLine(openLowLine)
    openHighLine := na
    openLowLine  := na

// ══════════════════════════════════════════════════════════════════════════════
// BUILD FIRST M15 CANDLE OF NEW YORK SESSION
// Works consistently on M1 / M5 / M15 because it uses the actual M15 time bucket
// ══════════════════════════════════════════════════════════════════════════════
if scriptActive and inSess and barstate.isconfirmed and not na(firstBucketTime)
    // Still inside the first M15 bucket
    if inOpenBucket and openBucketTime == firstBucketTime and not firstBucketLocked
        accH := na(accH) ? high : math.max(accH, high)
        accL := na(accL) ? low  : math.min(accL, low)

    // First M15 bucket has just ended -> lock the range once
    if not firstBucketLocked and inOpenBucket and openBucketTime != firstBucketTime
        fcHigh := accH
        fcLow  := accL
        sessRangeReady := not na(fcHigh) and not na(fcLow)
        firstBucketLocked := true

        if i_showOpenLines and sessRangeReady
            openHighLine := line.new(firstBucketTime, fcHigh, time_close, fcHigh, xloc=xloc.bar_time, extend=extend.none, color=i_colHigh, style=line.style_dotted, width=1)
            openLowLine  := line.new(firstBucketTime, fcLow,  time_close, fcLow,  xloc=xloc.bar_time, extend=extend.none, color=i_colLow,  style=line.style_dotted, width=1)

// Keep extending lines until end of New York session
if scriptActive and inSess and sessRangeReady and i_showOpenLines
    if not na(openHighLine)
        line.set_x2(openHighLine, time_close)
        line.set_y1(openHighLine, fcHigh)
        line.set_y2(openHighLine, fcHigh)
    if not na(openLowLine)
        line.set_x2(openLowLine, time_close)
        line.set_y1(openLowLine, fcLow)
        line.set_y2(openLowLine, fcLow)

// ══════════════════════════════════════════════════════════════════════════════
// SIGNALS
// Using opening M15 high/low
// ══════════════════════════════════════════════════════════════════════════════
var bool extUp = false
var bool extDown = false
var bool bullBreakActive = false
var bool bearBreakActive = false
var int  lastBullBoBar = na
var int  lastBearBoBar = na

if newSess and scriptActive
    extUp := false
    extDown := false
    bullBreakActive := false
    bearBreakActive := false
    lastBullBoBar := na
    lastBearBoBar := na

bool rangeReady = scriptActive and sessRangeReady and not na(fcHigh) and not na(fcLow)

if rangeReady and inSess
    extUp := extUp or high > fcHigh
    extDown := extDown or low < fcLow

bool prevCloseAboveHigh = rangeReady ? close[1] > fcHigh : false
bool prevCloseBelowLow  = rangeReady ? close[1] < fcLow : false

bool sigBullBO  = rangeReady and inSess and barstate.isconfirmed and close > fcHigh and close[1] <= fcHigh
bool sigBearBO  = rangeReady and inSess and barstate.isconfirmed and close < fcLow and close[1] >= fcLow
bool sigBearRev = rangeReady and inSess and barstate.isconfirmed and extUp and close <= fcHigh and close >= fcLow and (not i_strictRev or prevCloseAboveHigh)
bool sigBullRev = rangeReady and inSess and barstate.isconfirmed and extDown and close <= fcHigh and close >= fcLow and (not i_strictRev or prevCloseBelowLow)

if sigBullBO
    bullBreakActive := true
    lastBullBoBar := bar_index
if sigBearBO
    bearBreakActive := true
    lastBearBoBar := bar_index

bool invBull = rangeReady and inSess and barstate.isconfirmed and bullBreakActive and close <= fcHigh and close >= fcLow
bool invBear = rangeReady and inSess and barstate.isconfirmed and bearBreakActive and close <= fcHigh and close >= fcLow
if invBull
    bullBreakActive := false
if invBear
    bearBreakActive := false

bool sigRetestBull = rangeReady and inSess and barstate.isconfirmed and bullBreakActive and not na(lastBullBoBar) and bar_index > lastBullBoBar and low <= fcHigh and close > fcHigh
bool sigRetestBear = rangeReady and inSess and barstate.isconfirmed and bearBreakActive and not na(lastBearBoBar) and bar_index > lastBearBoBar and high >= fcLow and close < fcLow

var float sessRetestLow = na
var float sessRetestHigh = na
if newSess and scriptActive
    sessRetestLow := na
    sessRetestHigh := na
if sigRetestBull
    sessRetestLow := low
if sigRetestBear
    sessRetestHigh := high

// ══════════════════════════════════════════════════════════════════════════════
// SESSION TRADE GATES
// ══════════════════════════════════════════════════════════════════════════════
var bool tradedLongSess = false
var bool tradedShortSess = false
var bool tradedAnySess = false

if newSess and scriptActive
    tradedLongSess := false
    tradedShortSess := false
    tradedAnySess := false

bool flat = strategy.position_size == 0

bool wantLongBO  = i_useBO and i_long and sigBullBO
bool wantShortBO = i_useBO and i_short and sigBearBO
bool wantLongRV  = i_useRev and i_long and sigBullRev
bool wantShortRV = i_useRev and i_short and sigBearRev

bool allowLong  = tfTradeOk and flat and inSess and rangeReady and not (i_oneTotal and tradedAnySess) and not (i_onePerDir and tradedLongSess)
bool allowShort = tfTradeOk and flat and inSess and rangeReady and not (i_oneTotal and tradedAnySess) and not (i_onePerDir and tradedShortSess)

bool doLong  = (wantLongBO or wantLongRV) and allowLong
bool doShort = (wantShortBO or wantShortRV) and allowShort

// ══════════════════════════════════════════════════════════════════════════════
// STOP / TARGET HELPERS
// ══════════════════════════════════════════════════════════════════════════════
f_slLong(float ep, float sigLow) =>
    float s = na
    if i_slMode == "Opposite VA"
        s := fcLow - buf
    else if i_slMode == "First candle"
        s := fcLow - buf
    else if i_slMode == "Signal bar"
        s := sigLow - buf
    else if i_slMode == "Retest candle"
        s := (na(sessRetestLow) ? sigLow : sessRetestLow) - buf
    else
        s := ep - atrV * i_atrStopM
    s

f_slShort(float ep, float sigHigh) =>
    float s = na
    if i_slMode == "Opposite VA"
        s := fcHigh + buf
    else if i_slMode == "First candle"
        s := fcHigh + buf
    else if i_slMode == "Signal bar"
        s := sigHigh + buf
    else if i_slMode == "Retest candle"
        s := (na(sessRetestHigh) ? sigHigh : sessRetestHigh) + buf
    else
        s := ep + atrV * i_atrStopM
    s

f_tpLong(float ep, float sl) =>
    float risk = ep - sl
    float t = na
    if i_tpMode == "Fixed R multiple"
        t := ep + risk * i_tpR
    else if i_tpMode == "Opposite first candle"
        t := fcHigh
    else
        t := na
    t

f_tpShort(float ep, float sl) =>
    float risk = sl - ep
    float t = na
    if i_tpMode == "Fixed R multiple"
        t := ep - risk * i_tpR
    else if i_tpMode == "Opposite first candle"
        t := fcLow
    else
        t := na
    t

// ══════════════════════════════════════════════════════════════════════════════
// POSITION STATE
// ══════════════════════════════════════════════════════════════════════════════
var float longInitialSl = na
var float shortInitialSl = na
var float longRisk = na
var float shortRisk = na

if flat
    longInitialSl := na
    shortInitialSl := na
    longRisk := na
    shortRisk := na

// ══════════════════════════════════════════════════════════════════════════════
// ENTRIES
// ══════════════════════════════════════════════════════════════════════════════
if doLong
    float ep = close
    float sl0 = f_slLong(ep, low)
    float rk = ep - sl0
    if rk > 0
        longInitialSl := sl0
        longRisk := rk
        strategy.entry("L", strategy.long)
        tradedLongSess := true
        tradedAnySess := true
        if i_showLbl
            label.new(bar_index, low, "L " + (wantLongBO ? "BO" : "Rev"), style=label.style_label_up, color=color.teal, textcolor=color.white, size=size.small)

if doShort
    float ep = close
    float sl0 = f_slShort(ep, high)
    float rk = sl0 - ep
    if rk > 0
        shortInitialSl := sl0
        shortRisk := rk
        strategy.entry("S", strategy.short)
        tradedShortSess := true
        tradedAnySess := true
        if i_showLbl
            label.new(bar_index, high, "S " + (wantShortBO ? "BO" : "Rev"), style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// POSITION MANAGEMENT
// ══════════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed and tfTradeOk
    if strategy.position_size > 0 and not na(longInitialSl)
        float ep = strategy.position_avg_price
        float risk = nz(longRisk, ep - longInitialSl)
        float sl = longInitialSl
        if i_beR > 0 and risk > 0 and close >= ep + risk * i_beR
            sl := math.max(sl, ep)

        float tpFull = f_tpLong(ep, longInitialSl)
        float tpPart = risk > 0 ? ep + risk * i_partialR : na

        if i_tpMode == "Trailing only"
            float slTb = longInitialSl
            if i_beR > 0 and risk > 0 and close >= ep + risk * i_beR
                slTb := math.max(slTb, ep)
            float slT = math.max(slTb, trailFloorLong)
            strategy.exit("LX", from_entry="L", stop=slT)
        else if i_tpMode == "Partial R + trail" and risk > 0
            float slBase = longInitialSl
            if i_beR > 0 and risk > 0 and close >= ep + risk * i_beR
                slBase := math.max(slBase, ep)
            float slP = slBase
            float slR = math.max(slBase, trailFloorLong)
            strategy.exit("LXp", from_entry="L", qty_percent=i_partialPct, limit=tpPart, stop=slP)
            strategy.exit("LXr", from_entry="L", stop=slR)
        else
            sl := math.max(sl, trailFloorLong)
            strategy.exit("LX", from_entry="L", limit=tpFull, stop=sl)

    if strategy.position_size < 0 and not na(shortInitialSl)
        float ep = strategy.position_avg_price
        float risk = nz(shortRisk, shortInitialSl - ep)
        float sl = shortInitialSl
        if i_beR > 0 and risk > 0 and close <= ep - risk * i_beR
            sl := math.min(sl, ep)

        float tpFull = f_tpShort(ep, shortInitialSl)
        float tpPart = risk > 0 ? ep - risk * i_partialR : na

        if i_tpMode == "Trailing only"
            float slTb = shortInitialSl
            if i_beR > 0 and risk > 0 and close <= ep - risk * i_beR
                slTb := math.min(slTb, ep)
            float slT = math.min(slTb, trailCeilShort)
            strategy.exit("SX", from_entry="S", stop=slT)
        else if i_tpMode == "Partial R + trail" and risk > 0
            float slBase = shortInitialSl
            if i_beR > 0 and risk > 0 and close <= ep - risk * i_beR
                slBase := math.min(slBase, ep)
            float slP = slBase
            float slR = math.min(slBase, trailCeilShort)
            strategy.exit("SXp", from_entry="S", qty_percent=i_partialPct, limit=tpPart, stop=slP)
            strategy.exit("SXr", from_entry="S", stop=slR)
        else
            sl := math.min(sl, trailCeilShort)
            strategy.exit("SX", from_entry="S", limit=tpFull, stop=sl)

// Data window only
plot(scriptActive and sessRangeReady ? fcHigh : na, "Opening High", color=color.new(i_colHigh, 100), display=display.data_window)
plot(scriptActive and sessRangeReady ? fcLow  : na, "Opening Low",  color=color.new(i_colLow, 100),  display=display.data_window)