//@version=5
// ╔══════════════════════════════════════════════════════════════════════╗
// ║       MONDAY RANGE STRATEGY  |  ICT · SMC · Price Action            ║
// ║  Backtest on Daily (1D). One signal per week. Closes at Friday.      ║
// ╚══════════════════════════════════════════════════════════════════════╝
strategy("Monday Range Strategy [ICT/SMC]",
         overlay               = true,
         initial_capital       = 10000,
         default_qty_type      = strategy.percent_of_equity,
         default_qty_value     = 1,
         commission_type       = strategy.commission.percent,
         commission_value      = 0.05,
         slippage              = 2,
         process_orders_on_close = true,   // fill at bar close when signal fires
         max_boxes_count       = 200,
         max_lines_count       = 200,
         max_labels_count      = 200)

// ─── INPUTS ────────────────────────────────────────────────────────────
i_long       = input.bool(true,   "Allow Long Trades",          group="⚙️ Strategy")
i_short      = input.bool(true,   "Allow Short Trades",         group="⚙️ Strategy")
i_max_day    = input.string("Friday", "Trade Until (day)",      group="⚙️ Strategy", options=["Tuesday","Wednesday","Thursday","Friday"])
i_rr         = input.float(2.0,   "Risk : Reward Ratio",        group="⚙️ Strategy", minval=0.5, step=0.5)
i_sl_buf     = input.float(0.15,  "SL Buffer (× ATR-14)",       group="⚙️ Strategy", minval=0.0, step=0.05)
i_tp_mode    = input.string("Opposite Range", "TP Mode", group="⚙️ Strategy", options=["Opposite Range","Fixed RR"])
i_one_trade  = input.bool(true,   "Max 1 Trade Per Week",       group="⚙️ Strategy")
i_close_fri  = input.bool(true,   "Force Close on Friday",      group="⚙️ Strategy")
i_show_box   = input.bool(true,   "Show Monday Range Box",      group="📊 Visual")
i_show_sigs  = input.bool(true,   "Show Entry Signals",         group="📊 Visual")

// ─── DAY-OF-WEEK ──────────────────────────────────────────────────────
_dow     = dayofweek(time, syminfo.timezone)
is_mon   = _dow == dayofweek.monday
is_tue   = _dow == dayofweek.tuesday
is_wed   = _dow == dayofweek.wednesday
is_thu   = _dow == dayofweek.thursday
is_fri   = _dow == dayofweek.friday

max_dow  = switch i_max_day
    "Tuesday"   => dayofweek.tuesday
    "Wednesday" => dayofweek.wednesday
    "Thursday"  => dayofweek.thursday
    =>             dayofweek.friday

is_trade  = _dow >= dayofweek.tuesday and _dow <= max_dow
new_week  = ta.change(time("W")) != 0
atr14     = ta.atr(14)

// ─── MONDAY RANGE STATE ──────────────────────────────────────────────
var float MON_H   = na
var float MON_L   = na
var bool  sw_low  = false
var bool  sw_hi   = false
var bool  traded  = false   // one trade per week gate
var box   rbox    = na

if new_week
    MON_H   := na
    MON_L   := na
    sw_low  := false
    sw_hi   := false
    traded  := false
    if not na(rbox)
        box.delete(rbox)
        rbox := na

if is_mon
    MON_H := na(MON_H) ? high : math.max(MON_H, high)
    MON_L := na(MON_L) ? low  : math.min(MON_L, low)

mon_ended = is_tue and is_mon[1] and not na(MON_H)
if mon_ended and i_show_box
    rbox := box.new(bar_index - 1, MON_H, bar_index, MON_L,
         border_color=color.new(color.blue, 30), border_width=1,
         bgcolor=color.new(color.blue, 88))

if not is_mon and not na(rbox)
    box.set_right(rbox, bar_index)
if is_fri and not na(rbox)
    box.set_right(rbox, bar_index)

// ─── SIGNAL DETECTION ────────────────────────────────────────────────
bool  bull_mss = false
bool  bear_mss = false
float sw_l_ext = na
float sw_h_ext = na

can_trade = is_trade and not na(MON_H) and not na(MON_L) and
     (not i_one_trade or not traded) and strategy.position_size == 0

if can_trade
    // ── BULLISH MSS ──
    if low < MON_L and close > MON_L and not sw_low and i_long
        bull_mss := true
        sw_l_ext := low
        sw_low   := true

    // ── BEARISH MSS ──
    if high > MON_H and close < MON_H and not sw_hi and i_short
        bear_mss  := true
        sw_h_ext  := high
        sw_hi     := true

// ─── ENTRY / EXIT EXECUTION ──────────────────────────────────────────
buf = atr14 * i_sl_buf

if bull_mss and not na(sw_l_ext)
    sl_l = sw_l_ext - buf
    tp_l = i_tp_mode == "Opposite Range" ? MON_H : close + (close - sl_l) * i_rr
    strategy.entry("Long", strategy.long, comment="Long MSS ▲")
    strategy.exit("Long TP/SL", from_entry="Long", stop=sl_l, limit=tp_l,
                  comment_profit="TP ✓", comment_loss="SL ✗")
    traded := true
    if i_show_sigs
        label.new(bar_index, low,
             "▲ LONG\nSL: " + str.tostring(sl_l, format.mintick) +
             "\nTP: " + str.tostring(tp_l, format.mintick),
             style=label.style_label_up, color=color.teal,
             textcolor=color.white, size=size.normal)

if bear_mss and not na(sw_h_ext)
    sl_s = sw_h_ext + buf
    tp_s = i_tp_mode == "Opposite Range" ? MON_L : close - (sl_s - close) * i_rr
    strategy.entry("Short", strategy.short, comment="Short MSS ▼")
    strategy.exit("Short TP/SL", from_entry="Short", stop=sl_s, limit=tp_s,
                  comment_profit="TP ✓", comment_loss="SL ✗")
    traded := true
    if i_show_sigs
        label.new(bar_index, high,
             "▼ SHORT\nSL: " + str.tostring(sl_s, format.mintick) +
             "\nTP: " + str.tostring(tp_s, format.mintick),
             style=label.style_label_down, color=color.red,
             textcolor=color.white, size=size.normal)

// Force-close all positions at Friday close (weekend risk)
if i_close_fri and is_fri and strategy.position_size != 0
    strategy.close_all(comment="Fri Close")

// ─── DAY BACKGROUND ───────────────────────────────────────────────────
bgcolor(is_mon ? color.new(color.blue,   94) : na, title="Monday BG")
bgcolor(is_tue ? color.new(color.yellow, 96) : na, title="Tuesday BG")

// ─── PERFORMANCE TABLE ────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 7,
     bgcolor=color.new(color.black, 65), border_width=1,
     border_color=color.new(color.gray, 40),
     frame_width=1, frame_color=color.new(color.gray, 30))

if barstate.islast
    closed  = strategy.closedtrades
    wr      = closed > 0 ? strategy.wintrades / closed * 100.0 : 0.0
    pf      = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : na
    dd      = strategy.max_drawdown

    // Header
    table.cell(t, 0, 0, "Monday Range", text_color=color.white, text_size=size.small,
         bgcolor=color.new(color.blue, 45))
    table.cell(t, 1, 0, "ICT / SMC", text_color=color.white, text_size=size.small,
         bgcolor=color.new(color.blue, 45))
    // Stats
    table.cell(t, 0, 1, "Win Rate",      text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(wr, "#.1") + "%",
         text_color=wr >= 50 ? color.teal : color.red, text_size=size.small)
    table.cell(t, 0, 2, "Trades",        text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(closed),
         text_color=color.white, text_size=size.small)
    table.cell(t, 0, 3, "Net Profit",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(strategy.netprofit, "#.##"),
         text_color=strategy.netprofit >= 0 ? color.teal : color.red, text_size=size.small)
    table.cell(t, 0, 4, "Profit Factor", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 4, not na(pf) ? str.tostring(pf, "#.##") : "N/A",
         text_color=color.white, text_size=size.small)
    table.cell(t, 0, 5, "Max DD",        text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(dd, "#.##"),
         text_color=color.orange, text_size=size.small)
    table.cell(t, 0, 6, "RR Ratio",      text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 6, "1 : " + str.tostring(i_rr, "#.#"),
         text_color=color.white, text_size=size.small)